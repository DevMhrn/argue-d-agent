# Copy to .env and fill in when your keys arrive.
# Leave both keys blank to run in MOCK mode (no network, no keys needed).

# AI/ML API — frontier models (judgment, drafting). https://aimlapi.com
AIMLAPI_API_KEY=
# AIMLAPI_BASE_URL=https://api.aimlapi.com/v1

# Featherless AI — open-source models (extraction, high volume). https://featherless.ai
FEATHERLESS_API_KEY=
# FEATHERLESS_BASE_URL=https://api.featherless.ai/v1

# Force mock mode on/off. Unset = auto (mock when no keys present).
#   LUMEN_MOCK=1  -> always mock
#   LUMEN_MOCK=0  -> always real (requires keys)
LUMEN_MOCK=

# Per-agent model overrides (confirm exact model ids in each provider's catalog).
# MODEL_INTAKE=
# MODEL_EVIDENCE=
# MODEL_ADVOCATE=
# MODEL_OPPOSING=
# MODEL_ADJUDICATOR=
# MODEL_DRAFTER=

# Business thresholds
# ESCALATE_USD=25000
