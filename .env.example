# Copy to .env and fill in when your keys arrive.
# Leave ALL three keys blank to run in MOCK mode (no network, no keys needed).
# Each agent runs on one of three model families (Anthropic / Google / OpenAI),
# all reached via their OpenAI-compatible chat-completions endpoints.

# Anthropic (Claude) — Advocate, Adjudicator A, Drafter. https://console.anthropic.com
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/

# Google (Gemini) — Evidence, Adjudicator B, Verifier. https://aistudio.google.com
GEMINI_API_KEY=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# OpenAI (GPT) — Intake, Opposing red team. https://platform.openai.com
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Force mock mode on/off. Unset = auto (mock when no keys present).
#   LUMEN_MOCK=1  -> always mock
#   LUMEN_MOCK=0  -> always real (requires keys)
LUMEN_MOCK=

# Per-agent model overrides (confirm exact model ids in each provider's catalog).
# MODEL_INTAKE=gpt-4o-mini
# MODEL_EVIDENCE=gemini-2.5-flash
# MODEL_ADVOCATE=claude-opus-4-8
# MODEL_OPPOSING=gpt-4o
# MODEL_ADJUDICATOR=claude-opus-4-8
# MODEL_ADJUDICATOR_B=gemini-2.5-pro
# MODEL_VERIFIER=gemini-2.5-flash
# MODEL_DRAFTER=claude-sonnet-4-6

# Business thresholds
# ESCALATE_USD=25000
# PURSUE_MIN_USD=2500
# PURSUE_MIN_FAULT_PCT=25
