# =============================================================================
# Lumen — Environment Variables (template)
# =============================================================================
#
# Copy this file to `.env` (repo root) or `backend/.env` and fill in what you
# have — config.py loads both locations.
#     cp .env.example .env
#
# Empty values are fine for anything that isn't wired yet — the system runs
# in MOCK mode when no LLM keys are present, so the offline CLI demo works
# with zero configuration.
#
# Sections:
#   1. LLM providers          — Anthropic + Google (Gemini) + OpenAI (required for LIVE mode)
#   2. Mode toggles           — MOCK / LIVE / Band SDK / ledger lane
#   3. Per-agent models       — per-agent overrides if you want non-default models
#   4. FastAPI server         — HTTP port
#   5. Supabase (Postgres)    — required for ingestion + ledger + orchestration writes
#   6. Backblaze B2 (storage) — required for raw-file uploads
#   7. Redis (Upstash)        — required for the async extraction queue
#   8. Business thresholds    — escalation / viability rules
#   9. Ingestion limits       — upload size caps and worker tuning
#
# Never commit your real .env. `.env` and `backend/.env` are both in .gitignore.
# Share credentials through a private channel, not the repo.


# -----------------------------------------------------------------------------
# 1. LLM providers — required for LIVE mode (three independent model families,
#    all reached via their OpenAI-compatible chat-completions endpoints)
# -----------------------------------------------------------------------------

# Anthropic (Claude) — Advocate, Adjudicator A, Drafter. https://console.anthropic.com
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/

# Google (Gemini) — Evidence, Adjudicator B, Verifier. https://aistudio.google.com
GEMINI_API_KEY=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# OpenAI (GPT) — Intake, Opposing red team. https://platform.openai.com
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1


# -----------------------------------------------------------------------------
# 2. Mode toggles
# -----------------------------------------------------------------------------

# Force mock mode on/off. Unset = auto (mock when no LLM keys present).
#   LUMEN_MOCK=1  -> always mock (deterministic, offline, no network)
#   LUMEN_MOCK=0  -> always live (requires the three provider keys above)
LUMEN_MOCK=

# Pace the mock so the live web room is watchable. Real mode is paced by latency.
# LUMEN_MOCK_DELAY_MS=650

# Activate the real Band SDK room (vs the LocalRoom stand-in).
# Requires band_config.yaml at the repo root (see backend/app/band_config.example.yaml).
# LUMEN_BAND=1

# Build the evidence ledger from the graph lane (default on). Set 0 to use the
# inline evidence agent instead.
# LUMEN_USE_LEDGER=1


# -----------------------------------------------------------------------------
# 3. Per-agent model overrides (optional)
# -----------------------------------------------------------------------------
# Defaults live in backend/app/config.py — override only when needed.
# Confirm exact model ids in each provider's catalog before using.
# MODEL_INTAKE=gpt-4o-mini
# MODEL_EVIDENCE=gemini-2.5-flash
# MODEL_ADVOCATE=claude-opus-4-8
# MODEL_OPPOSING=gpt-4o
# MODEL_ADJUDICATOR=claude-opus-4-8
# MODEL_ADJUDICATOR_B=gemini-2.5-pro
# MODEL_VERIFIER=gemini-2.5-flash
# MODEL_DRAFTER=claude-sonnet-4-6


# -----------------------------------------------------------------------------
# 4. FastAPI server
# -----------------------------------------------------------------------------

# HTTP port the backend listens on.
PORT=3000


# -----------------------------------------------------------------------------
# 5. Supabase / Postgres
# -----------------------------------------------------------------------------
# Create a free project at https://supabase.com. After creation, apply the SQL
# migrations:
#     ./run.sh setup                       # if not already done
#     .venv/bin/python -m scripts.apply_migrations
#
# IMPORTANT — Supabase has retired the legacy "db.<project-ref>.supabase.co"
# hostname for new projects. Use the Supavisor pooler. Find both URLs at:
#     Project Settings → Database → Connection string
#
# Two pooler flavors:
#   Session pooler   (port 5432) — supports prepared statements + persistent
#                                  connections. Use for migrations and long-lived
#                                  workers (FastAPI uvicorn, arq). ← DEFAULT
#   Transaction pooler (port 6543) — cycles connections per query. No prepared
#                                    statements. Use for serverless / FaaS only.
#
# Both username forms include the project ref: postgres.<project-ref>.
# Password must be URL-encoded (%40 = @, %23 = #, etc.).

# Primary connection — session pooler. Used by every Python process by default.
DATABASE_URL=postgresql://postgres.<project-ref>:<url-encoded-password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# Optional: transaction-pool variant for future serverless deployment.
DATABASE_URL_TRANSACTION=postgresql://postgres.<project-ref>:<url-encoded-password>@aws-1-<region>.pooler.supabase.com:6543/postgres

# Individual components — match the session pooler above.
DB_HOST=aws-1-<region>.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.<project-ref>
DB_PASSWORD=<your-supabase-database-password>

# Supabase SDK URL (REST + Realtime + Storage) — derived from project ref.
SUPABASE_URL=https://<project-ref>.supabase.co

# *** REQUIRED *** Service-role key (backend-only — NEVER expose to frontend).
# Get from: Supabase dashboard → Project Settings → API → "service_role"
SUPABASE_SERVICE_KEY=

# *** OPTIONAL *** Anon/public key (safe for frontend, only needed if the
# frontend talks to Supabase directly e.g. for Realtime subscriptions).
SUPABASE_ANON_KEY=


# -----------------------------------------------------------------------------
# 6. Backblaze B2 (object storage for raw uploaded files)
# -----------------------------------------------------------------------------
# Create a free account at https://www.backblaze.com/cloud-storage. Create a
# bucket (default name: "lumen-case-files"), then generate an Application Key
# scoped to that bucket with read/write/delete permission.
#
# B2 speaks the S3-compatible API at https://s3.<region>.backblazeb2.com.
# Our storage adapter uses boto3 with a custom endpoint_url.

B2_KEY_ID=
B2_APPLICATION_KEY=

# Bucket name — must match what you created in the B2 console.
B2_BUCKET=lumen-case-files

# Region depends on which cluster the bucket lives in. Check the bucket details
# page in the B2 console — the S3-endpoint URL shows the region.
# Common values: us-west-001/002, us-east-005, eu-central-003.
B2_REGION=us-east-005
B2_ENDPOINT_URL=https://s3.us-east-005.backblazeb2.com


# -----------------------------------------------------------------------------
# 7. Redis (Upstash) — required for the async extraction queue
# -----------------------------------------------------------------------------
# Create a free Redis at https://upstash.com. Upstash provides both native
# Redis-protocol connection (rediss://) and an HTTP REST URL. We use the
# native protocol for arq.
#
# IMPORTANT — REDIS_URL must use the `rediss://` scheme (two s's) to enable
# TLS. Upstash requires TLS — `redis://` (no s) will fail to connect.

REDIS_URL=rediss://default:<token>@<endpoint>.upstash.io:6379

# *** OPTIONAL *** REST endpoints for HTTP-based Redis clients (upstash-redis JS
# or Python). Not used by `arq`. Handy if frontend or HTTP-only code needs
# direct Redis access.
UPSTASH_REDIS_REST_URL=https://<endpoint>.upstash.io
UPSTASH_REDIS_REST_TOKEN=


# -----------------------------------------------------------------------------
# 8. Business thresholds (optional — defaults in code)
# -----------------------------------------------------------------------------

# Recovery amount above which a case is auto-escalated to a human reviewer.
# ESCALATE_USD=25000

# Below these, pursuing the recovery isn't worth the cost → recommend DECLINE.
# PURSUE_MIN_USD=2500
# PURSUE_MIN_FAULT_PCT=25

# Adjudicator confidence below which a case is escalated (0.0 - 1.0).
# ESCALATE_CONFIDENCE_BELOW=0.60

# Adjudicator consensus tolerance (percentage points). If the two adjudicators
# disagree by more than this, the case is escalated.
# CONSENSUS_TOLERANCE_PP=10


# -----------------------------------------------------------------------------
# 9. Ingestion limits (optional — defaults in code)
# -----------------------------------------------------------------------------

# Hard cap on a single uploaded file's size (bytes). Default 50 MiB.
# Frontend pre-validates against this; the sign-upload endpoint enforces it.
# INGEST_MAX_FILE_SIZE_BYTES=52428800

# Hard cap on the number of documents per case. Default 50.
# INGEST_MAX_DOCS_PER_CASE=50

# Pre-signed upload URL TTL (seconds). Default 300 (5 minutes).
# INGEST_UPLOAD_URL_TTL=300

# How many extraction workers run in parallel against the queue.
# INGEST_WORKER_CONCURRENCY=4

# Default tenant UUID used when no tenant is specified (single-tenant demo).
# Matches the DB column default in 001_initial.sql.
# INGEST_DEMO_TENANT_ID=00000000-0000-0000-0000-000000000001
